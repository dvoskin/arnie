# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM Provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Anthropic — required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Default model for run_turn main pass. Opus 4.7 for coaching reasoning;
# Haiku 4.5 is used internally for low-latency voice/cleanup tasks.
DEFAULT_MODEL=claude-opus-4-7

# OpenAI — required for ALL voice features (Whisper transcription of inbound
# voice notes AND tts-1 for spoken replies); also used if LLM_PROVIDER=openai.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ── Proactive & voice toggles ────────────────────────────────────────────────
# Master switch for ALL proactive outreach (timed nudges, weekly recap, etc).
# Nothing is sent until this is true.
PROACTIVE_MESSAGING_ENABLED=false
# Attach a TTS voice note to PROACTIVE messages (morning briefing, evening pacing,
# hook re-asks). Telegram only. Defaults ON when proactive is on.
VOICE_PROACTIVE_ENABLED=true
# Reply to an inbound VOICE note with a spoken voice note (in addition to text).
# Telegram only. Requires OPENAI_API_KEY. Defaults OFF.
VOICE_REPLIES_ENABLED=false

# Database (SQLite default — no changes needed locally)
DATABASE_URL=sqlite+aiosqlite:///arnie.db

# Web search (Tavily) — powers Arnie's generic web_search tool.
# OFF by default; the tool is inert and absent from the tool list unless enabled.
SEARCH_ENABLED=false
TAVILY_API_KEY=your_tavily_api_key_here

# Optional webhook mode (leave empty to use polling — easier for local dev)
WEBHOOK_URL=
WEBHOOK_PORT=8443
